# Database (Supabase)
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-this"

# Redis (Upstash)
REDIS_HOST=xxxx.upstash.io
REDIS_PORT=6379

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# VNPay (optional - bỏ qua nếu chưa cần)
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-web-app.vercel.app/payments/vnpay-return

# CORS
CORS_ORIGIN=https://your-web-app.vercel.app

# URLs
FRONTEND_URL=https://your-web-app.vercel.app
BACKEND_URL=https://your-api.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
